{
  "manifest_version": 3,
  "name": "PodsyPro Etsy Analyzer",
  "version": "1.0.0",
  "description": "Analyze Etsy listings and shops directly from the sidebar.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.etsy.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-D5Ep4IYz.js"
      ],
      "matches": [
        "*://*.etsy.com/*"
      ]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open PodsyPro Analyzer"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.etsy.com/*"
      ],
      "resources": [
        "assets/content.ts-D5Ep4IYz.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
