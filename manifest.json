{
  "manifest_version": 3,
  "name": "PodsyPro Etsy Analyzer",
  "version": "1.0.0",
  "description": "Analyze Etsy listings and shops directly from the sidebar.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.etsy.com/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.etsy.com/*", "*://localhost/*", "*://*.podsy.pro/*"],
      "js": ["src/content.ts"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open PodsyPro Analyzer"
  }
}
