generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  shops     Shop[]
}

model KeywordQuery {
  id             String    @id @default(uuid())
  keyword        String    @unique
  listingIds     String    @default("")
  lastQueriedAt  DateTime  @default(now())
}

model Shop {
  id            String          @id @default(uuid())
  userId        String
  etsyShopId    String          @unique
  shopName      String
  accessToken   String?
  refreshToken  String?
  totalSales    Int             @default(0)
  hasFullDetails Boolean        @default(false)
  rawJson       String          @default("{}")
  lastQueriedAt DateTime        @default(now())
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id])
  listings      Listing[]
  snapshots     ShopSnapshot[]
  receipts      Receipt[]
  transactions  Transaction[]
}

model ShopSnapshot {
  id         String   @id @default(uuid())
  shopId     String
  totalSales Int
  createdAt  DateTime @default(now())
  shop       Shop     @relation(fields: [shopId], references: [id])
}

model Listing {
  id            String            @id @default(uuid())
  shopId        String
  etsyId        String            @unique
  title         String
  description   String?
  price         Float?
  views         Int               @default(0)
  favorites     Int               @default(0)
  imagesJson    String            @default("[]")
  videosJson    String            @default("[]")
  tagsJson      String            @default("[]")
  inventoryJson String            @default("{}")
  propertiesJson String           @default("[]")
  reviewsJson   String            @default("[]")
  shippingPrice Float?
  url           String            @default("")
  hasFullDetails Boolean          @default(false)
  rawJson       String            @default("{}")
  lastQueriedAt DateTime          @default(now())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now())
  shop          Shop              @relation(fields: [shopId], references: [id])
  snapshots     ListingSnapshot[]
}

model ListingSnapshot {
  id          String   @id @default(uuid())
  listingId   String
  views       Int
  favorites   Int
  price       Float?
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id])
}

model TrackedItem {
  id        String   @id @default(uuid())
  keyword   String
  volume    Int      @default(0)
  createdAt DateTime @default(now())
}

model SearchCache {
  id        String   @id @default(uuid())
  query     String   @unique
  data      String   // JSON stringified results
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalysisCache {
  id        String   @id @default(uuid())
  type      String   // "keyword", "listing", "shop"
  targetId  String   
  data      String   // JSON stringified analysis result
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, targetId])
}

model CronJob {
  id        String   @id @default(uuid())
  name      String   @unique
  lastRun   DateTime?
  status    String   @default("idle")
}

model TrendData {
  id        String   @id @default(uuid())
  niche     String
  score     Float
  createdAt DateTime @default(now())
}

model PodAsset {
  id        String   @id @default(uuid())
  name      String
  url       String
  type      String   // "cmyk_print", "mockup", "video"
  createdAt DateTime @default(now())
}

model GeneratedListing {
  id        String   @id @default(uuid())
  prompt    String
  status    String   @default("pending") // pending, generating, ready, published
  resultUrl String?
  createdAt DateTime @default(now())
}

model AiReport {
  id        String   @id @default(uuid())
  type      String   // "weekly", "monthly"
  content   String
  audioUrl  String?
  createdAt DateTime @default(now())
}

model Receipt {
  id               String        @id @default(uuid())
  shopId           String
  receiptId        String        @unique // Etsy's receipt_id
  buyerEmail       String?
  buyerUserId      String?
  creationTsz      Int           // Creation timestamp from Etsy
  grandtotal       Float?
  subtotal         Float?
  discountAmt      Float?
  shippingCost     Float?
  status           String?       // paid, shipped, etc.
  messageFromBuyer String?
  rawJson          String        @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  shop             Shop          @relation(fields: [shopId], references: [id])
  transactions     Transaction[]
}

model Transaction {
  id             String   @id @default(uuid())
  receiptId      String
  shopId         String
  transactionId  String   @unique // Etsy's transaction_id
  title          String
  description    String?
  quantity       Int
  price          Float
  shippingCost   Float?
  listingId      String?  // Etsy's listing_id if available
  productId      String?
  rawJson        String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  receipt        Receipt  @relation(fields: [receiptId], references: [id])
  shop           Shop     @relation(fields: [shopId], references: [id])
}
