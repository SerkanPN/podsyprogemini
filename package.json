{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:ext": "vite build -c vite.config.ext.ts -w",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist-server/server.cjs",
    "build:ext": "vite build -c vite.config.ext.ts",
    "start": "node dist-server/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bullmq": "^5.80.7",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.1",
    "@types/socket.io": "^3.0.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.12",
    "prisma": "^7.8.0",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
